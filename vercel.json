{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/metas.html",
      "dest": "/metas.html"
    },
    {
      "src": "/metas-disciplinas.html",
      "dest": "/metas-disciplinas.html"
    },
    {
      "src": "/videos.html",
      "dest": "/videos.html"
    },
    {
      "src": "/agent-command-center.html",
      "dest": "/agent-command-center.html"
    },
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    }
  ]
}
