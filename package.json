{
  "name": "create-trivium-method-editorial",
  "version": "1.0.0",
  "description": "Scaffolder oficial do Trivium Method Editorial — framework de produção didática com agentes de IA.",
  "type": "module",
  "bin": {
    "create-trivium-method-editorial": "bin/create-trivium-method-editorial.js"
  },
  "files": [
    "bin/",
    "src/",
    "scaffold/",
    "docs/framework/TRIVIUM-METHOD-EDITORIAL-ADJUSTMENTS.md",
    "docs/framework/TRIVIUM-METHOD-EDITORIAL-ARCHITECTURE.md",
    "docs/framework/TRIVIUM-METHOD-EDITORIAL-HIERARCHY.md",
    "docs/guides/TRIVIUM-METHOD-EDITORIAL-DISCIPLINE-ONBOARDING.md",
    "docs/guides/TRIVIUM-METHOD-EDITORIAL-INSTALLATION.md",
    "docs/stories/README.md",
    "trivium-method-editorial/",
    "public/app.js",
    "public/metas-disciplinas.js",
    "public/metas.js",
    "public/sidebar.js",
    "public/styles.css",
    "public/videos.js",
    "index.html",
    "metas.html",
    "metas-disciplinas.html",
    "videos.html",
    "agent-command-center.html",
    "vercel.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:artifacts": "node scripts/generate-trivium-method-editorial-artifacts.mjs",
    "lint": "node scripts/quality/lint.mjs",
    "publish:lesson:github": "node scripts/publish-lesson-github.mjs",
    "publish:lesson:github:ui": "node scripts/publish-lesson-github-ui.mjs",
    "playwright:install": "PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=1 playwright install",
    "playwright:open": "PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=1 playwright open",
    "playwright:test": "PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=1 playwright test",
    "typecheck": "node scripts/quality/typecheck.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": [
    "trivium-method-editorial",
    "editorial-framework",
    "classical-education",
    "christian-education",
    "ai-agents",
    "npx-installer"
  ],
  "author": "Italo Gabriel",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
